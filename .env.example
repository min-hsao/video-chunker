# video-chunker environment variables
# Copy this to .env and fill in your API keys

# Required for LLM chunk analysis (default: deepseek-chat)
DEEPSEEK_API_KEY=sk-...

# Optional: only needed if using --whisper-mode openai
OPENAI_API_KEY=sk-...

# Optional: LM Studio local URL (default: http://localhost:1234/v1)
# LMSTUDIO_BASE_URL=http://localhost:1234/v1
