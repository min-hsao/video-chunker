# video-chunker environment variables
# Copy this to .env and fill in your API keys

# Required for transcription (Whisper API)
OPENAI_API_KEY=sk-...

# Required for LLM chunk analysis when using DeepSeek (default)
DEEPSEEK_API_KEY=sk-...

# Optional: override default models
# VIDEO_CHUNKER_LLM_MODEL=deepseek-chat
# VIDEO_CHUNKER_WHISPER_MODEL=whisper-1
