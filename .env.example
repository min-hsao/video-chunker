# video-chunker environment variables
# Copy this to .env and fill in your API keys

# Required for transcription (Whisper API — always OpenAI)
OPENAI_API_KEY=sk-...

# Required for LLM chunk analysis when using DeepSeek (default)
DEEPSEEK_API_KEY=sk-...

# Optional: LM Studio local URL (default: http://localhost:1234/v1)
# LMSTUDIO_BASE_URL=http://localhost:1234/v1
